# Pay-on-green / Vercel demo controls
# The baked demo runs in-process (no flag needed). Caller-supplied `run` workspaces
# execute arbitrary code — pick an executor:
#   PAYONGREEN_SANDBOX=1     → isolated Vercel Sandbox microVM (safe; use on Vercel)
#   PAYONGREEN_ALLOW_RUN=1   → local subprocess (trusted dev box ONLY; not on Vercel)
PAYONGREEN_SANDBOX=0
PAYONGREEN_ALLOW_RUN=0
PAYONGREEN_ERC8004_AGENT_ID=101
PAYONGREEN_WRITE_ERC8004=0

# Vercel Sandbox auth for LOCAL testing of the `run` path (automatic via OIDC on Vercel).
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=
# VERCEL_PROJECT_ID=

# x402 pay-on-green receivable. Disabled unless X402_PAYONGREEN_REQUIRED=1.
X402_PAYONGREEN_REQUIRED=0
X402_RECEIVER_ADDRESS=
X402_NETWORK=base-sepolia
X402_ASSET=USDC
X402_AMOUNT=0.01
X402_FACILITATOR_URL=
X402_DEMO_MODE=0

# Walrus (Sui) evidence endpoints (optional; sensible testnet defaults used if omitted)
NEXT_PUBLIC_WALRUS_PUBLISHER=
NEXT_PUBLIC_WALRUS_AGGREGATOR=
NEXT_PUBLIC_WALRUS_STORE_PATH=
NEXT_PUBLIC_WALRUS_READ_PATH=
